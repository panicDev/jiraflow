# jiraflow — environment variables example
# Copy to .env and fill in your values:
#   cp .env.example .env

# Required
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token-from-id.atlassian.com

# Optional — restrict MCP server to specific projects (comma-separated)
# JIRA_PROJECTS_FILTER=PROJ,DEV

# Optional — default project key added to all JQL queries automatically
# JIRA_DEFAULT_PROJECT=PROJ

# Required for non-Claude-Code agents (Codex, OpenCode, Pi, etc.)
# Set to the absolute path of this plugin directory
# JIRAFLOW_ROOT=/path/to/jiraflow
